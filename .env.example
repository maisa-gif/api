# Copy to .env and fill in real values locally (or via your secrets manager
# in deployed environments). .env is gitignored — never commit real secrets.

# Postgres connection string. Use a hosted provider in production (Vercel
# Postgres, Neon, Supabase, ...) — SQLite/local files don't persist across
# Vercel serverless invocations.
DATABASE_URL="postgresql://user:password@localhost:5432/api_dev"

# Clínica nas Nuvens — internal app credentials (see https://api.clinicanasnuvens.com.br)
# These are issued once per app registration and are shown read-only in the
# integrations settings UI. The per-clinic token/hash (clinicaNasNuvens-cid)
# is NOT set here — it's entered and stored per-integration via the settings
# UI / PATCH /api/integrations/CLINICA_NAS_NUVENS.
CLINICA_NAS_NUVENS_CLIENT_ID=
CLINICA_NAS_NUVENS_CLIENT_SECRET=
# Optional override, defaults to https://api.clinicanasnuvens.com.br
# CLINICA_NAS_NUVENS_BASE_URL=

# Google Calendar — OAuth app credentials from Google Cloud Console
# (APIs & Services > Credentials > OAuth client ID > Web application),
# with the Google Calendar API enabled and
# "{APP_URL}/api/integrations/google-calendar/callback" registered as an
# authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public URL this app is reachable at (used to build the OAuth redirect URI).
APP_URL=http://localhost:3000

# Shared secret the /api/cron/sync-agenda endpoint checks for
# (Authorization: Bearer $CRON_SECRET). Vercel Cron sends this
# automatically when CRON_SECRET is set as an env var on the project.
CRON_SECRET=
# IANA timezone used when creating Google Calendar events from CNN
# appointments. Defaults to America/Sao_Paulo.
# SYNC_TIME_ZONE=
