# Copy to .env and fill in real values locally (or via your secrets manager
# in deployed environments). .env is gitignored — never commit real secrets.

DATABASE_URL="file:./dev.db"

# Clínica nas Nuvens — internal app credentials (see https://api.clinicanasnuvens.com.br)
# These are issued once per app registration and are shown read-only in the
# integrations settings UI. The per-clinic token/hash (clinicaNasNuvens-cid)
# is NOT set here — it's entered and stored per-integration via the settings
# UI / PATCH /api/integrations/CLINICA_NAS_NUVENS.
CLINICA_NAS_NUVENS_CLIENT_ID=
CLINICA_NAS_NUVENS_CLIENT_SECRET=
# Optional override, defaults to https://api.clinicanasnuvens.com.br
# CLINICA_NAS_NUVENS_BASE_URL=
